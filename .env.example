KIE_API_KEY=your_kie_key
KIE_BASE_URL=https://api.kie.ai
KIE_MODEL=gemini-2.5-flash

# Embedded VLESS+Reality tunnel.
#
# When set, the app spawns an in-process Xray-core at startup that listens on
# 127.0.0.1:10808 (HTTP proxy), and ALL three Dio clients (kie.ai, Brickognize,
# Rebrickable) route through it. To upstream observers (RKN/DPI), traffic
# looks like a regular TLS handshake to www.cloudflare.com.
#
# Empty value -> direct mode (no tunnel).
VLESS_URL=

# Optional: get a free key at https://rebrickable.com/api/
# Enables "Load by set number" flow which skips photo OCR.
REBRICKABLE_API_KEY=
