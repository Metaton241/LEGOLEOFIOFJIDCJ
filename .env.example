# ──────────────────────────────────────────────────────────────────
# Production (recommended): use the Cloudflare Worker relay.
# The relay holds the kie.ai API key as a Worker secret, so KIE_API_KEY
# stays empty here. See worker/README.md for deployment instructions.
# ──────────────────────────────────────────────────────────────────
KIE_API_KEY=
KIE_BASE_URL=https://relay.your-domain.com/kie
KIE_MODEL=gemini-2.5-flash

# ──────────────────────────────────────────────────────────────────
# Direct mode (for local development, when relay isn't deployed yet).
# Uncomment these and comment out the relay block above.
# ──────────────────────────────────────────────────────────────────
# KIE_API_KEY=your_kie_key_here
# KIE_BASE_URL=https://api.kie.ai
# KIE_MODEL=gemini-2.5-flash

# Optional: get a free key at https://rebrickable.com/api/
# When set, enables "Load by set number" flow which skips photo OCR.
REBRICKABLE_API_KEY=
