KIE_API_KEY=your_kie_key
KIE_BASE_URL=https://api.kie.ai
KIE_MODEL=gemini-2.5-flash

# HTTP CONNECT proxy. Leave PROXY_HOST empty to use direct mode.
# When set, ALL three Dio clients (kie.ai, Brickognize, Rebrickable) will
# tunnel HTTPS through this proxy. TLS to upstream still happens end-to-end
# AFTER the CONNECT, so the proxy operator cannot decrypt request bodies.
#
# WARNING: in this mode the kie.ai API key and the proxy credentials both
# live inside the APK and are visible to anyone who reverse-engineers it.
# For higher security, use the Cloudflare Worker relay instead (see worker/).
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=

# Optional: get a free key at https://rebrickable.com/api/
# Enables "Load by set number" flow which skips photo OCR.
REBRICKABLE_API_KEY=
