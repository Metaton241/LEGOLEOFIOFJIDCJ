# ─────────────────────────────────────────────────────────────────────────
# Production (recommended): Cloudflare Worker relay
#
# After deploying the Worker (see worker/README.md), the Worker holds the
# kie.ai API key as a Cloudflare secret. The app calls the Worker URL
# WITHOUT an Authorization header — the Worker injects it server-side.
# ─────────────────────────────────────────────────────────────────────────
KIE_API_KEY=
KIE_BASE_URL=https://twink-relay.<your-account>.workers.dev/kie
KIE_MODEL=gemini-2.5-flash

# ─────────────────────────────────────────────────────────────────────────
# Direct mode (development only — kie.ai may be blocked from RU networks)
# ─────────────────────────────────────────────────────────────────────────
# KIE_API_KEY=your_kie_key_here
# KIE_BASE_URL=https://api.kie.ai

# Optional: enables "Load by set number" flow (skips photo OCR).
# Get a free key at https://rebrickable.com/api/
REBRICKABLE_API_KEY=
